# Copy this file to .env and adjust values for your machine.
#
# Pipe-separated URL lists are used for browser tab arrays.
# Example: URL_ONE|URL_TWO|URL_THREE

# Shared launcher defaults.
PL_TERM=kitty
PL_BROWSER=chromium
PL_FILE_MANAGER=nautilus
PL_LAUNCH_DELAY=0.8
PL_RESET_TMUX=0

# Workspace 4 web apps.
WHATSAPP_COMMAND='omarchy-launch-webapp "https://web.whatsapp.com/"'
HEY_COMMAND='omarchy-launch-webapp "https://app.hey.com"'

# OC launcher.
OC_PROJECT_NAME=OC
OC_PROJECT_ID=oc
OC_SESSION=oc
OC_ROOT_DIR="$HOME/dev/your-oc-root"
OC_FRONTEND_DIR="$HOME/dev/your-oc-frontend"
OC_CONFIG_FRONTEND_DIR="$HOME/dev/your-oc-config-frontend"
OC_CODEX_DIR="$OC_ROOT_DIR"
OC_NVIM_DIR="$OC_ROOT_DIR"
OC_RUN_DIR="$OC_ROOT_DIR"
OC_CODEX_COMMAND="nvm use 22 && codex"
OC_NVIM_COMMAND="nvim ."
OC_DOCKER_START_COMMAND="docker start your_config_db your_backend_db"
OC_SERVER_COMMAND="nvm use 22 && npm run dev:server"
OC_BACKEND_COMMAND="nvm use 22 && npm run dev:backend"
OC_FRONTEND_COMMAND="nvm use 22 && npm run start:local"
OC_CONFIG_FRONTEND_COMMAND="nvm use 22 && npm run start:local:fixed"
OC_APP_URLS="http://localhost:4200|http://localhost:4201"
OC_JIRA_URLS="https://example.atlassian.net/jira/software/projects/PROJECT/boards/1/backlog"
OC_RIGHT_BROWSER_URLS="https://mail.google.com|https://drive.google.com|https://calendar.google.com|https://cloud.digitalocean.com/apps|https://github.com/your-org/your-repo"
OC_MANAGED_RESIZES=""

# Bestconnect launcher.
BESTCONNECT_PROJECT_NAME=Bestconnect
BESTCONNECT_PROJECT_ID=bc
BESTCONNECT_SESSION=bestconnect
BESTCONNECT_ROOT_DIR="$HOME/dev/your-bestconnect-root"
BESTCONNECT_FRONTEND_DIR="$HOME/dev/bcb-frontend"
BESTCONNECT_FRONTEND_PROXY_CONFIG="$HOME/.config/project-launch/config/bcb-proxy.conf.local.json"
BESTCONNECT_CODEX_DIR="$BESTCONNECT_ROOT_DIR"
BESTCONNECT_NVIM_DIR="$BESTCONNECT_ROOT_DIR"
BESTCONNECT_RUN_DIR="$BESTCONNECT_ROOT_DIR"
BESTCONNECT_CODEX_COMMAND=codex
BESTCONNECT_NVIM_COMMAND="nvim ."
BESTCONNECT_PREFLIGHT_COMMAND="systemctl is-active --quiet nginx || sudo systemctl start nginx"
BESTCONNECT_DOCKER_START_COMMAND="docker compose up -d"
BESTCONNECT_BACKEND_COMMAND="deno task dev"
BESTCONNECT_FRONTEND_COMMAND="npm run start -- --proxy-config $BESTCONNECT_FRONTEND_PROXY_CONFIG"
BESTCONNECT_LOG_COMMAND="docker compose logs -f"
BESTCONNECT_TEST_COMMAND="deno test --allow-read --allow-write --allow-env --unstable"
BESTCONNECT_APP_URLS="http://localhost:4200"
BESTCONNECT_JIRA_URLS="https://example.atlassian.net/jira/software/projects/PROJECT/boards/1/backlog"
BESTCONNECT_RIGHT_BROWSER_URLS="https://mail.google.com|https://drive.google.com|https://calendar.google.com|https://cloud.digitalocean.com/apps|https://github.com/your-org/your-repo"
BESTCONNECT_MANAGED_RESIZES=""
